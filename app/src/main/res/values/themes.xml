<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CruzeiroEcoSul" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:statusBarColor">@color/toolbar</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.CruzeiroEcoSul" parent="Base.Theme.CruzeiroEcoSul" />

    <style name="ImagemArredondada">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ImagemCardArredondada">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="TextAppearance.CruzeiroEcoSul.Heading" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="TextAppearance.CruzeiroEcoSul.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.CruzeiroEcoSul.CardTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.CruzeiroEcoSul.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="TextAppearance.CruzeiroEcoSul.BodyStart" parent="TextAppearance.CruzeiroEcoSul.Body">
        <item name="android:gravity">start</item>
    </style>

    <style name="TextAppearance.CruzeiroEcoSul.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CruzeiroEcoSul.CardVertical" parent="Widget.Material3.CardView.Outlined">
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="android:layout_marginVertical">@dimen/linear_gap</item>
    </style>

    <style name="Widget.CruzeiroEcoSul.CardHorizontal" parent="Widget.Material3.CardView.Outlined">
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="android:layout_marginVertical">@dimen/linear_gap</item>
    </style>

</resources>