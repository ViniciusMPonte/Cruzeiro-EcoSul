<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="titulo" format="string" />
    <attr name="corTitulo" format="color" />
    <attr name="descricao" format="string" />
    <attr name="corDescricao" format="color" />

    <declare-styleable name="CardHorizontal">
        <attr name="titulo" />
        <attr name="corTitulo" />
        <attr name="descricao" />
        <attr name="corDescricao" />
        <attr name="icone" format="reference" />
        <attr name="corIcone" format="color" />
        <attr name="corFundoIcone" format="color" />
        <attr name="corCard" format="color" />
        <attr name="paddingContainer" format="dimension" />
    </declare-styleable>

    <declare-styleable name="CardVertical">
        <attr name="titulo" />
        <attr name="descricao" />
        <attr name="imagem" format="reference" />
        <attr name="chip" format="string" />
    </declare-styleable>
</resources>