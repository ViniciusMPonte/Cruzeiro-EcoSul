    <string name="inicio_titulo">Pequenas ações, grande impacto</string>
    <string name="inicio_subtitulo">Cuidar do planeta é cuidar de nós mesmos e das próximas gerações. Cada escolha consciente faz a diferença.</string>
    <string name="inicio_secao_por_que">Por que agir agora?</string>

    <!-- Card: Recicle seu lixo -->
    <string name="inicio_card1_titulo">Recicle seu lixo</string>
    <string name="inicio_card1_descricao">Separe materiais recicláveis e ajude a reduzir a poluição e o desperdício.</string>

    <!-- Card: Economize água -->
    <string name="inicio_card2_titulo">Economize água</string>
    <string name="inicio_card2_descricao">Pequenas atitudes no dia a dia evitam o desperdício e preservam esse recurso essencial.</string>

