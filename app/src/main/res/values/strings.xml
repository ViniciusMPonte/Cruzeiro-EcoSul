    <string name="sobre_titulo">Sobre o App</string>
    <string name="sobre_descricao">O Cruzeiro EcoSul é um aplicativo educativo criado para incentivar práticas sustentáveis no dia a dia. Nosso objetivo é conscientizar e inspirar pessoas a cuidarem do planeta com pequenas atitudes que geram grandes transformações.</string>

    <!-- Seção: Nossa Missão -->
    <string name="sobre_missao_titulo">Nossa Missão</string>
    <string name="sobre_missao_descricao">Promover a sustentabilidade por meio da informação, educação e inspiração, contribuindo para um futuro melhor para todos.</string>

