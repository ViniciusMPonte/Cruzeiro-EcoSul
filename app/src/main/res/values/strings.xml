    <string name="dicas_titulo">Dicas Sustentáveis</string>
    <string name="dicas_subtitulo">Confira hábitos simples para o dia a dia</string>

    <!-- Dica 1: Energia -->
    <string name="dica1_titulo">Use energia de forma consciente</string>
    <string name="dica1_descricao">Desligue luzes e aparelhos quando não estiver usando. Pequenas atitudes economizam recursos e reduzem impactos ambientais.</string>
    <string name="dica1_tag">Energia</string>

    <!-- Dica 2: Reciclagem -->
    <string name="dica2_titulo">Separe e recicle seus resíduos</string>
    <string name="dica2_descricao">A separação correta dos materiais facilita a reciclagem e ajuda a transformar o que seria lixo em novos produtos.</string>
    <string name="dica2_tag">Reciclagem</string>

    <!-- Dica 3: Água -->
    <string name="dica3_titulo">Economize água todos os dias</string>
    <string name="dica3_descricao">Feche a torneira ao escovar os dentes, tome banhos mais curtos e reutilize água sempre que possível.</string>
    <string name="dica3_tag">Água</string>

    <!-- Dica 4: Consumo -->
    <string name="dica4_titulo">Consuma de forma responsável</string>
    <string name="dica4_descricao">Prefira produtos duráveis, evite desperdícios e apoie marcas sustentáveis sempre que puder.</string>
    <string name="dica4_tag">Consumo</string>

    <!-- ======================== -->
