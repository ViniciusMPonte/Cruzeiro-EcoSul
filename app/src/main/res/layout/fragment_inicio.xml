<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/page_margin"
    android:textAlignment="center">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="256dp"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ImagemArredondada"
        app:srcCompat="@drawable/hero" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="@dimen/text_center_width"
        android:layout_height="wrap_content"
        android:text="Pequenas ações, grande impacto"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.CruzeiroEcoSul.Heading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="@dimen/text_center_width"
        android:layout_height="wrap_content"
        android:text="Cuidar do planeta é cuidar de nós mesmos e das próximas gerações. Cada escolha consciente faz a diferença."
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.CruzeiroEcoSul.Body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <unicsul.pdm.cruzeiroecosul.componentes.CardHorizontal
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:descricao="Separe materiais recicláveis e ajude a reduzir a poluição."
        app:icone="@drawable/eco"
        app:titulo="Recicle seu lixo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

</androidx.constraintlayout.widget.ConstraintLayout>