<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/page_margin"
    android:textAlignment="center">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/logo" />

    <unicsul.pdm.cruzeiroecosul.componentes.CardHorizontal
        style="@style/Widget.CruzeiroEcoSul.CardHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:corCard="@color/background"
        app:corTitulo="@color/primary"
        app:descricao="Separe materiais recicláveis e ajude a reduzir a poluição."
        app:icone="@drawable/eco"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2"
        app:strokeColor="@color/background"
        app:titulo="Recicle seu lixo" />

</androidx.constraintlayout.widget.ConstraintLayout>