    <string name="inicio_titulo">Small actions, big impact</string>
    <string name="inicio_subtitulo">Caring for the planet means caring for ourselves and future generations. Every conscious choice makes a difference.</string>
    <string name="inicio_secao_por_que">Why act now?</string>

    <!-- Card: Recycle your waste -->
    <string name="inicio_card1_titulo">Recycle your waste</string>
    <string name="inicio_card1_descricao">Separate recyclable materials and help reduce pollution and waste.</string>

    <!-- Card: Save water -->
    <string name="inicio_card2_titulo">Save water</string>
    <string name="inicio_card2_descricao">Small daily habits prevent waste and preserve this essential resource.</string>

