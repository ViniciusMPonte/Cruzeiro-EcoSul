    <string name="dicas_titulo">Sustainable Tips</string>
    <string name="dicas_subtitulo">Simple daily habits to get started</string>

    <!-- Tip 1: Energy -->
    <string name="dica1_titulo">Use energy mindfully</string>
    <string name="dica1_descricao">Turn off lights and appliances when not in use. Small habits save resources and reduce environmental impact.</string>
    <string name="dica1_tag">Energy</string>

    <!-- Tip 2: Recycling -->
    <string name="dica2_titulo">Sort and recycle your waste</string>
    <string name="dica2_descricao">Properly sorting materials makes recycling easier and turns what would be trash into new products.</string>
    <string name="dica2_tag">Recycling</string>

    <!-- Tip 3: Water -->
    <string name="dica3_titulo">Save water every day</string>
    <string name="dica3_descricao">Turn off the tap while brushing your teeth, take shorter showers, and reuse water whenever possible.</string>
    <string name="dica3_tag">Water</string>

    <!-- Tip 4: Consumption -->
    <string name="dica4_titulo">Consume responsibly</string>
    <string name="dica4_descricao">Choose durable products, avoid waste, and support sustainable brands whenever you can.</string>
    <string name="dica4_tag">Consumption</string>

